# Application
PORT=8081
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5433/garage_billing

# AWS (LocalStack for local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# SQS
SQS_ENDPOINT=http://localhost:4566
SQS_BILLING_COMMANDS_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/garage-billing-commands
SQS_BILLING_REPLIES_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/garage-billing-replies

# Mercado Pago
MERCADO_PAGO_MOCK=true
MERCADO_PAGO_ACCESS_TOKEN=your_sandbox_token_here
# Public URL MP will POST to when the payment status changes.
# In local dev, expose http://localhost:8081/webhook/mercadopago via ngrok:
#   ngrok http 8081
# then use the https URL ngrok prints, e.g.
#   MERCADO_PAGO_WEBHOOK_URL=https://abcd-1234.ngrok-free.app/webhook/mercadopago
MERCADO_PAGO_WEBHOOK_URL=

# Datadog
DD_API_KEY=your_api_key_here
DD_APP_KEY=your_app_key_here
DD_SERVICE=garage-billing-service
DD_ENV=development
DD_VERSION=1.0.0
DD_AGENT_HOST=localhost
DD_TRACE_ENABLED=false
